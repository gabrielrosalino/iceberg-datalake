AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000

# DockerHub is only the container registry.
# ECS/Fargate pulls this image and executes the processing task.
PROCESSING_IMAGE=gabrielrosalino/iceberg-datalake-processing:latest

# ECS resources used by Airflow EcsRunTaskOperator.
ECS_CLUSTER_NAME=iceberg-datalake-dev-cluster
ECS_TASK_DEFINITION=iceberg-datalake-dev-processing
ECS_CONTAINER_NAME=processing
ECS_SUBNET_IDS=subnet-xxxxxxxx,subnet-yyyyyyyy
ECS_SECURITY_GROUP_IDS=sg-xxxxxxxx
ECS_LAUNCH_TYPE=FARGATE
ECS_ASSIGN_PUBLIC_IP=ENABLED

# S3 Tables / Iceberg.
S3_TABLE_BUCKET_NAME=iceberg-datalake-dev-tables
S3_TABLE_NAMESPACE_BRONZE=bronze
S3_TABLE_NAMESPACE_SILVER=silver
S3_TABLE_NAMESPACE_GOLD=gold
S3_TABLE_WAREHOUSE=s3tables://iceberg-datalake-dev-tables

# S3 bucket for raw API payloads, dbt artifacts, logs and Athena query results.
S3_ARTIFACTS_BUCKET=iceberg-datalake-dev-artifacts
RAW_DATA_PREFIX=raw/open_meteo
ATHENA_RESULTS_PREFIX=athena-results

# Runtime variables inside the ECS processing container.
DUCKDB_DATABASE=/app/data/duckdb/lakehouse.duckdb
DBT_PROJECT_DIR=/app/dbt
DBT_PROFILES_DIR=/app/dbt
OPEN_METEO_DAYS_BACK=30
